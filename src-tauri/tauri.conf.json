{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "汽修接待与车辆保险管理",
  "version": "0.1.0",
  "identifier": "com.chengxu.repairmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "汽修接待与车辆保险管理",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720,
        "maximized": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGMTlBQjVEQkVGM0YxOTMKUldTVDhmTytYYXNaNzhWRHdXYzFObjI3N2k2QUpGN25BdThnVS9JdGlBNU11OXFZWUZ4Vk84RmsK",
      "endpoints": [
        "https://chengxu.pages.dev/api/client-updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
