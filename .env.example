# Copy this file to .env when local configuration is needed.
# Do not commit the real .env file.

APP_NAME=汽修接待与车辆保险管理
DATABASE_PATH=./data/app.sqlite
EXPORT_DIR=./exports

# Tencent Cloud COS configuration for settlement receipt images.
# Fill real values in Cloudflare Pages environment variables or secrets.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-beijing

# Tauri updater signing. Keep real values only in local/CI secrets.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Public client release metadata. Configure these in Cloudflare Pages.
DESKTOP_RELEASE_VERSION=
DESKTOP_RELEASE_PUBLISHED_AT=
DESKTOP_RELEASE_SIZE=
DESKTOP_RELEASE_NOTES=
DESKTOP_RELEASE_DOWNLOAD_URL=
DESKTOP_RELEASE_UPDATE_URL=
DESKTOP_RELEASE_SIGNATURE=
ANDROID_RELEASE_VERSION=
ANDROID_RELEASE_PUBLISHED_AT=
ANDROID_RELEASE_SIZE=
ANDROID_RELEASE_NOTES=
ANDROID_RELEASE_DOWNLOAD_URL=
